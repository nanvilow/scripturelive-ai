modules = ["nodejs-24", "python-3.11"]

# v0.7.18 deploy fix — In a pnpm workspace Replit reads the production
# build/run from each artifact's `.replit-artifact/artifact.toml`, NOT
# from this file. Putting `build` and `run` here causes them to run as
# a PRE-build hook BEFORE each artifact's own build, doubling the work
# and risking OOM. So we keep this section minimal and only declare the
# deployment target.
[deployment]
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "imported-app-build"

[[workflows.workflow]]
name = "imported-app-build"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/imported-app && SKIP_MARKETING_PREBUILD=1 NODE_OPTIONS=--max-old-space-size=3584 NEXT_TELEMETRY_DISABLED=1 NODE_ENV=production pnpm run build"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 240000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]

[userenv.development]

[userenv.production]

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3001

[[ports]]
localPort = 21238
externalPort = 80

[[ports]]
localPort = 25650
externalPort = 3000

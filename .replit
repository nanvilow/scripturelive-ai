modules = ["nodejs-24", "python-3.11"]

# v0.7.18 deploy fix — In a pnpm workspace Replit reads the production
# build/run from each artifact's `.replit-artifact/artifact.toml`, NOT
# from this file. Putting `build` and `run` here causes them to run as
# a PRE-build hook BEFORE each artifact's own build, doubling the work
# and risking OOM. So we keep this section minimal and only declare the
# deployment target.
[deployment]
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 240000

# v0.7.18 deploy fix — Autoscale requires exactly ONE externally
# forwarded port. The Next.js production server (server.mjs) listens
# on 25650 and serves both the UI/HTTP API AND the Deepgram WebSocket
# stream from the same origin, so a single forward is all production
# needs. Dev workflows for api-server (8080) and mockup-sandbox (8081)
# bind their own internal ports and remain reachable in the workspace
# preview pane via the path-based artifact router defined in their
# respective .replit-artifact/artifact.toml files — they do NOT
# require [[ports]] entries here.
[[ports]]
localPort = 25650
externalPort = 80

[nix]
channel = "stable-25_05"

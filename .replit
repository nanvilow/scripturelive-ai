modules = ["nodejs-24", "python-3.11"]

# v0.7.18 deploy fix — In a pnpm workspace Replit reads the production
# build/run from each artifact's `.replit-artifact/artifact.toml`, NOT
# from this file. Putting `build` and `run` here causes them to run as
# a PRE-build hook BEFORE each artifact's own build, doubling the work
# and risking OOM. So we keep this section minimal and only declare the
# deployment target.
[deployment]
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 240000

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 25650
externalPort = 3000

[userenv]

[userenv.shared]

[userenv.development]

[userenv.production]

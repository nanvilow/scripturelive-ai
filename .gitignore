# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc
*.tsbuildinfo
.expo
.expo-shared

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# next.js
/.next/
/out/

# production builds
/build
/coverage

# misc
/.sass-cache
/connect.lock
/libpeerconnection.log
*.pem

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
testem.log
/typings

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
next-env.d.ts

# System Files
.DS_Store
Thumbs.db

# Tooling rules / configs that shouldn't be committed
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md
.claude
.z-ai-config

# Local-only logs / scratch
*.log
dev.log
dev.out.log
server.log
local-*
test
prompt

# Skills directory (when created locally)
/skills/

# Replit
.cache/
.local/

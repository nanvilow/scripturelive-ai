{
  "name": "@workspace/imported-app",
  "version": "0.7.6",
  "private": true,
  "main": "dist-electron/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/nanvilow/scripturelive-ai.git"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@prisma/client",
      "@prisma/engines",
      "@swc/core",
      "electron",
      "electron-winstaller",
      "es5-ext",
      "esbuild",
      "koffi",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  },
  "scripts": {
    "inject:keys": "node scripts/inject-keys.mjs",
    "predev": "node scripts/inject-keys.mjs",
    "prebuild": "node scripts/inject-keys.mjs",
    "dev": "cross-env DATABASE_URL=file:../db/custom.db next dev -H 0.0.0.0 -p ${PORT:-3000}",
    "build": "cross-env DATABASE_URL=file:../db/custom.db prisma generate && cross-env DATABASE_URL=file:../db/custom.db next build",
    "start": "cross-env DATABASE_URL=file:../db/custom.db NODE_ENV=production HOST=0.0.0.0 PORT=${PORT:-3000} node server.mjs",
    "postinstall": "node -e \"process.exit(0)\"",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "bash scripts/run-e2e.sh",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "electron:build": "tsc -p electron/tsconfig.json",
    "electron:dev": "pnpm run electron:build && cross-env NEXT_DEV_URL=http://localhost:3000 electron dist-electron/main.js",
    "package": "pnpm run build && pnpm run electron:build && electron-builder --config electron-builder.yml && pnpm run downloads:manifest",
    "package:win": "pnpm run build && pnpm run electron:build && electron-builder --config electron-builder.yml --win --publish never && pnpm run downloads:manifest",
    "package:mac": "pnpm run build && pnpm run electron:build && electron-builder --config electron-builder.yml --mac && pnpm run downloads:manifest",
    "downloads:manifest": "node scripts/update-download-manifest.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.1.1",
    "@mdxeditor/editor": "^3.39.1",
    "@prisma/client": "^6.11.1",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-context-menu": "^2.2.15",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-hover-card": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-toggle-group": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@reactuses/core": "^6.0.5",
    "@tanstack/react-query": "^5.82.0",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.3.9",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.23.2",
    "hash-wasm": "^4.12.0",
    "input-otp": "^1.4.2",
    "koffi": "^2.16.1",
    "lucide-react": "^0.525.0",
    "next": "^16.1.1",
    "next-auth": "^4.24.11",
    "next-intl": "^4.3.4",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.6",
    "openai": "^6.34.0",
    "prisma": "^6.11.1",
    "react": "^19.0.0",
    "react-day-picker": "^9.8.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.60.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^3.0.3",
    "react-syntax-highlighter": "^15.6.1",
    "recharts": "^2.15.4",
    "remark-breaks": "^4.0.0",
    "sharp": "^0.34.3",
    "sonner": "^2.0.6",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^11.1.0",
    "vaul": "^1.1.2",
    "ws": "^8.20.0",
    "yjs": "^13.6.30",
    "z-ai-web-dev-sdk": "^0.0.17",
    "zod": "^4.0.2",
    "zustand": "^5.0.6"
  },
  "_ndi_note": "NDI output is implemented via koffi (FFI) calling directly into Processing.NDI.Lib.x64.dll from the user's NDI Tools/Runtime install. koffi ships a precompiled win32-x64 .node binary inside its npm tarball, so there is NO node-gyp / Visual Studio Build Tools / electron-rebuild step. The runtime DLL is located at app start by walking NDI_RUNTIME_DIR_V6 / V5 / V4 env vars and the standard NDI install path. See electron/ndi-service.ts.",
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "bun-types": "^1.3.4",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "playwright": "~1.49.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}

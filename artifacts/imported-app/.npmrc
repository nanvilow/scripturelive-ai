auto-install-peers=true
strict-peer-dependencies=false
# CRITICAL: use the hoisted linker (npm-style flat node_modules) for this
# package. The default `isolated` linker stores real files under
# node_modules/.pnpm/<pkg>@<ver>/node_modules/<pkg>/ and only symlinks
# them into node_modules/<pkg>/. electron-builder's asar packer can't
# follow those symlinks reliably on Windows, which causes runtime
# require('grandiose') to fail with "Cannot find module 'grandiose'"
# even though the .npmrc shows it installed. Hoisted linker installs
# grandiose (and every other dep) as REAL files at node_modules/grandiose/,
# which then asarUnpack'd cleanly.
node-linker=hoisted
shamefully-hoist=true

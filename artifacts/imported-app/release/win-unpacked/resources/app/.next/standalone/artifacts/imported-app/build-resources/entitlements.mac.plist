<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required by V8 (Electron's JavaScript engine). -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Required so `grandiose` can dlopen the NDI runtime dylib that
         end-users install separately via NDI Tools. The NDI dylib is
         signed by NewTek/Vizrt, not by us, so library validation would
         otherwise reject it. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- The bundled Next.js server binds a local TCP port and the app
         talks to it; NDI itself is also LAN traffic. -->
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.network.server</key>
    <true/>
</dict>
</plist>

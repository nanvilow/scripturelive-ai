generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Song {
  id          String   @id @default(cuid())
  title       String
  artist      String?
  lyrics      String   // Raw lyrics text
  structured  String?  // AI-structured JSON: {sections: [{type, label, lines}]}
  category    String   @default("worship") // worship, hymn, gospel, contemporary
  tags        String?  // Comma-separated tags
  keySignature String?
  tempo       Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  presentations Presentation[]
}

model SermonNote {
  id          String   @id @default(cuid())
  title       String
  content     String   // Rich text content (Markdown or HTML)
  outline     String?  // JSON outline structure
  bibleRefs   String?  // Comma-separated Bible references
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  presentations Presentation[]
}

model Presentation {
  id          String   @id @default(cuid())
  title       String
  slides      String   // JSON: [{type, title, subtitle, content, background}]
  songId      String?
  sermonId    String?
  bibleRefs   String?  // Comma-separated Bible references
  theme       String   @default("default") // default, worship, sermon
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  song   Song?       @relation(fields: [songId], references: [id])
  sermon SermonNote? @relation(fields: [sermonId], references: [id])
}

model BibleVerseCache {
  id          String   @id @default(cuid())
  reference   String   // e.g. "John 3:16"
  translation String   // KJV, NIV, etc.
  text        String   // The verse text
  book        String
  chapter     Int
  verseStart  Int
  verseEnd    Int?
  createdAt   DateTime @default(now())

  @@unique([reference, translation])
}

// Tracks which translations have been downloaded for offline use.
// A row is created when the user starts a download from Settings →
// Bible → Offline. `progress` is 0–100 while downloading and 100
// once the entire Bible (or just the cached subset) is on disk.
model BibleTranslationDownload {
  id           String   @id @default(cuid())
  translation  String   @unique // e.g. "KJV"
  name         String   // human label, e.g. "King James Version"
  language     String   @default("en")
  status       String   @default("pending") // pending | downloading | ready | error
  progress     Int      @default(0)
  bookCount    Int      @default(0)
  verseCount   Int      @default(0)
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Whole-chapter cache — much faster than verse-by-verse for offline
// browsing. Populated by /api/bible/translations download job and
// consulted by the Bible lookup routes before falling back to the
// public API.
model BibleChapterCache {
  id          String   @id @default(cuid())
  translation String
  book        String
  chapter     Int
  verses      String   // JSON: [{verse: 1, text: "..."}, ...]
  createdAt   DateTime @default(now())

  @@unique([translation, book, chapter])
  @@index([translation, book])
}

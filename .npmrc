auto-install-peers=false
strict-peer-dependencies=false
# Hoist lightningcss + its platform-specific native binaries to the top-level
# node_modules so Tailwind v4 / @tailwindcss/postcss can resolve the
# `../lightningcss.<platform>.node` require path correctly. Without this,
# the Next.js build fails on macOS/Windows runners with
# "Cannot find module '../lightningcss.darwin-arm64.node'" or similar.
public-hoist-pattern[]=*lightningcss*
public-hoist-pattern[]=@tailwindcss/*

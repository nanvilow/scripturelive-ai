# The format of this file is identical to `.dockerignore`.
#
# CRITICAL: This file filters BOTH (a) the source upload from the local
# workspace to Replit's build container AND (b) the final runtime layer
# packaged into the Autoscale container image. Anything ignored here is
# ALSO missing at runtime. The previous version of this file used
# `.next/` and `**/node_modules/`, which silently stripped the
# freshly-built Next.js standalone bundle and `next` package itself
# from every deploy and made the autoscale container fail to start
# (`Cannot find module '.next/standalone/.../server.mjs'`,
# `Cannot find package 'next'`). Do NOT add `.next/` here.
# Do NOT add unanchored `**/node_modules/` here.

# Replit-internal scratch dir
.local

# Replit local pnpm store / build cache (~1.5 GB). Replit's deploy
# rebuilds whatever it needs; shipping our local copy just bloats the
# upload past the publish-size limit.
.cache/
.config/

# Source-control history (deploy doesn't need it)
.git/

# Editor / OS noise
.DS_Store
*.log
*.tsbuildinfo

# Screenshots from chat / local screenshot dir (not referenced by the
# production server)
attached_assets/
screenshots/

# Workspace-root release output dirs. `exports/` at the repo root is
# ~3 GB of historical ScriptureLive-AI-v*.zip builds; `download/` and
# `release/` are operator-distribution staging dirs. None of these are
# served by the web app — the app reads downloads from
# `artifacts/imported-app/download/` instead.
/exports/
/download/
/downloads/
/release/

# Local-only Windows Electron desktop build artifacts. The production
# Linux autoscale server never serves these — they are built locally
# by BUILD.bat for distribution to Windows operators.
artifacts/imported-app/dist-electron/
artifacts/imported-app/dist-electron-ui/
artifacts/imported-app/exports/
artifacts/imported-app/download/
# v0.7.67 deploy fix — `artifacts/imported-app/release/` is the
# electron-builder output dir. After a local `BUILD.bat` /
# `pnpm package:win` run this dir holds:
#   - ScriptureLive-AI-X.Y.Z-Setup-x64.exe   (~490 MB)
#   - win-unpacked/                          (~1.9 GB unpacked Electron)
#   - .blockmap, .yml, builder-debug.yml, etc.
# Total: 2.7 GB. The web autoscale runtime never serves this — the
# Windows installer is distributed via GitHub Releases. Including it
# in the deploy tarball is what pushed the image past Cloud Run's
# 8 GiB limit ("The deployment image size exceeds the 8 GiB limit").
# Anchored path (NOT a `**/release/` glob) so we don't accidentally
# strip a directory literally named `release` from inside any
# transitive node_modules tree.
artifacts/imported-app/release/

# v0.7.67 deploy fix — User-uploaded media accumulated in dev. These
# live on the operator's local disk in production (the runtime writes
# uploads to a per-user path managed by the storage adapter), not in
# the Git tree. Shipping the dev copies into the deploy image just
# bloats the upload tarball by another ~110 MB with content that gets
# overwritten on first user action anyway.
artifacts/imported-app/uploads/
artifacts/imported-app/upload/

# v0.7.67 deploy fix — Repo-root scratch media (chat-attached preview
# clips, asset-manager screen recordings). Already covered for
# `attached_assets/` and `screenshots/` above; this is the same
# category for media that landed at the repo root with timestamped
# names (`Asset-Manager-*.mp4`, etc.).
/Asset-Manager-*.mp4
/Asset-Manager-*.mov
/*.mp4
/*.mov

# Turbopack cache (regenerated on each build)
artifacts/imported-app/.turbo/
.turbo/

# Hoisted workspace `node_modules` — re-installed by the deploy build
# phase. We use ANCHORED paths (NOT `**/node_modules`) because the
# globbed pattern would also strip `.next/standalone/node_modules/`,
# which is the production bundle's self-contained dependency tree
# (next, ws, prisma client, etc.). Stripping that breaks the
# standalone server entirely — that exact bug cost six failed deploys.
/node_modules
/artifacts/*/node_modules
/lib/*/node_modules
/scripts/node_modules
/packages/*/node_modules
